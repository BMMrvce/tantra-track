{
  "name": "tantratrack",
  "version": "1.0.0",
  "private": true,
  "description": "Budget Tracker - Track income, expenses, and generate reports",
  "type": "module",
  "main": "server/index.js",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start": "npm run dev",
    "client": "cd client && npm start",
    "server": "cd server && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm run build",
    "vercel-build": "cd client && npm run build",
    "install:all": "npm install"
  },
  "dependencies": {},
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
